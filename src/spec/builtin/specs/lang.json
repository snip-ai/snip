[
  {
    "name": "cargo-check",
    "surface": "bash",
    "bind": { "cmd": "cargo", "subcommands": ["build", "check", "clippy"] },
    "inject_flags": ["--message-format=json", "--color=never"],
    "transforms": [
      { "op": "parse", "format": "cargo_json" },
      { "op": "rank", "by": "errors_first" },
      { "op": "truncate", "head": 60, "tail": 20 }
    ]
  },
  {
    "name": "cargo",
    "surface": "bash",
    "bind": { "cmd": "cargo", "subcommands": ["test", "run", "bench"] },
    "inject_flags": ["--color=never"],
    "transforms": [
      { "op": "test_rollup", "pred": { "match": "ends_with", "value": " ... ok" } },
      { "op": "dedupe" },
      { "op": "fold_frames" },
      { "op": "truncate", "head": 40, "tail": 40 }
    ]
  },
